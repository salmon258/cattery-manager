NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (VAPID) — generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Anthropic (powers the per-cat Ask-AI card). Optional — leave blank to
# disable the feature at runtime.
ANTHROPIC_API_KEY=
# Override the model if desired. Default is claude-opus-4-7.
ANTHROPIC_MODEL=
